# SWE.1 Requirements Generator - Environment Configuration
# Copy this file to .env and customize for your environment

# Database Configuration
DATABASE_URL=postgresql://swe1_user:swe1_secure_password@localhost:5432/swe1_generator

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=jeffh/intfloat-e5-base-v2:f32
GENERATION_MODEL=codellama:34b

# AI Processing Configuration
DEFAULT_CHUNK_SIZE=256
SIMILARITY_THRESHOLD=0.7
SIMILARITY_TOP_K=5
MAX_GENERATION_TOKENS=2048

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO

# Optional: Hybrid Retrieval (EPIC 8.5)
RETRIEVAL_MODE=hybrid
RETRIEVAL_ALPHA=0.4
RETRIEVAL_BETA=0.6
ELASTICSEARCH_URL=http://localhost:9200
HYBRID_EMBEDDING_MODEL=paraphrase-multilingual:278m-mpnet-base-v2-fp16